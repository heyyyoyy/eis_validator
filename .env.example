# eis_validator environment variables
# Copy this file to .env and adjust values for your environment.
# .env is gitignored and must never be committed.

# ── Backend ───────────────────────────────────────────────────────────────────
# These vars are interpolated into docker-compose.yml (${VAR:-default} syntax).
# They are NOT injected directly into containers via env_file — only the values
# explicitly listed under each service's `environment:` block reach the container.
#
# For local `cargo run` (outside Docker), export these in your shell or a separate
# .env loaded by your shell (e.g. `export $(cat .env | xargs)`).

# Port the backend listens on.
PORT=3000

# Log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Production ports (docker-compose.prod.yml only) ──────────────────────────

# Host port mapped to the nginx HTTP listener (redirects to HTTPS).
# Defaults to 80 when unset.
# HTTP_PORT=80

# Host port mapped to the nginx HTTPS listener.
# Defaults to 443 when unset.
# HTTPS_PORT=443

# ── cert-gen (Docker only) ────────────────────────────────────────────────────

# Directory inside the cert-gen container where certs are written.
# Maps to the shared "certs" Docker volume.
# CERTS_DIR=/certs

# Certificate validity period in days.
# CERT_DAYS=365

# OpenSSL subject for the generated certificate.
# CERT_SUBJECT=/CN=localhost

# Subject Alternative Names (comma-separated).
# CERT_SAN=DNS:localhost,DNS:frontend,IP:127.0.0.1
