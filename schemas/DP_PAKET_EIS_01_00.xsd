																	<xs:documentation>Торговое наименование</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЛекФорм" type="Строка500Тип" use="required">
																<xs:annotation>
																	<xs:documentation>Лекарственная форма</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="Доз" type="Строка500Тип">
																<xs:annotation>
																	<xs:documentation>Дозировка.
Устарело, оставлено для обратной совместимости</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
													<xs:element name="ДозСвед" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Сведения о дозировке.
Контролируется обязательность заполнения при приеме</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:attribute name="Наим" type="Строка500Тип" use="required">
																<xs:annotation>
																	<xs:documentation>Наименование</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="Знач" type="ЧислоМакс10ДоТочкТип" use="required">
																<xs:annotation>
																	<xs:documentation>Значение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
													<xs:element name="НаимЕдИзм" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Наименование единицы измерения до и после изменения.
Блок игнорируется при приеме.
Атрибуты блока заполняются при передаче полным наименованием единицы измерения по справочнику ОКЕИ.

Единицу измерения ЛП невозможно изменить в УКД относительно УПД, блок добавлен для формирования ПФ</xs:documentation>
														</xs:annotation>
														<xs:complexType>
