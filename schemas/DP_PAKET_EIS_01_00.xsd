				<xs:annotation>
					<xs:documentation>Наименование</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Опис" type="Строка2000Тип" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Описание</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Контент" type="КонтентТип" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Полный текст ошибки</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
