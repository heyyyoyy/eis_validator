																				<xs:documentation>До изменения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="ПослеИзм" type="ЧислоМакс18ДоТочкТип" use="required">
																			<xs:annotation>
																				<xs:documentation>После изменения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="ЗарегПредОтпЦена" type="ЧислоМакс18ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Зарегистрированная предельная отпускная цена ЛП, руб.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
												<xs:attribute name="НомСтр" type="Число6Тип">
													<xs:annotation>
														<xs:documentation>Номер строки таблицы. Требуется обязательное заполнение</xs:documentation>
													</xs:annotation>
												</xs:attribute>
