<?xml version="1.0" encoding="windows-1251"?>
<!-- DP_PACKET_EIS_01_00 -->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:jaxb="http://java.sun.com/xml/ns/jaxb" xmlns:sch="http://purl.oclc.org/dsdl/schematron" xmlns:usch="http://www.unisoftware.ru/schematron-extensions" elementFormDefault="qualified" attributeFormDefault="unqualified" jaxb:version="2.1">
	<xs:annotation>
		<xs:documentation>Элемент транспортного пакета</xs:documentation>
	</xs:annotation>
	<xs:element name="ФайлПакет">
		<xs:annotation>
			<xs:documentation>Транспортный пакет для передачи основного документа, приложения к нему и вложений</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Документ" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Документ.
Контролируется заполнение блока при приеме из внешней системы. Не заполняется при передаче между подсистемами</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Контент" type="КонтентТип">
								<xs:annotation>
									<xs:documentation>Контент</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="ПодписьДокумент" type="ПодписьТип" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Подпись и сведения о лице, подписывающем контент</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
						<xs:attribute name="ДокументИд" type="ГУИД32Тип">
							<xs:annotation>
								<xs:documentation>Идентификатор контента документа в хранилище документов.

Игнорируется при приеме, заполняется в ЕИС после выхода версии 14.1</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="Прилож" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Приложение к документу</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Контент" type="КонтентТип">
								<xs:annotation>
									<xs:documentation>Контент</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="ПодписьПрилож" type="ПодписьТип" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Подпись и сведения о лице, подписывающем контент</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
						<xs:attribute name="ДокументИд" type="ГУИД32Тип">
							<xs:annotation>
								<xs:documentation>Идентификатор контента приложения в хранилище документов.

Игнорируется при приеме, заполняется в ЕИС после выхода версии 14.1</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="Вложен" minOccurs="0" maxOccurs="unbounded">
					<xs:annotation>
						<xs:documentation>Прикрепленные документы</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:choice>
								<xs:element name="Ссылк" type="СсылкаТип">
									<xs:annotation>
										<xs:documentation>Ссылка для скачивания прикрепленного документа</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="ОтносСсылка">
									<xs:annotation>
										<xs:documentation>Относительная ссылка</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:attribute name="КонтентИд" type="ГУИД32Тип" use="required">
											<xs:annotation>
												<xs:documentation>Уникальный идентификатор контента прикрепленного документа в ЕИС</xs:documentation>
											</xs:annotation>
										</xs:attribute>
										<xs:attribute name="ТипФХ" use="required">
											<xs:annotation>
												<xs:documentation>Тип файлового хранилища</xs:documentation>
											</xs:annotation>
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:enumeration value="ЛКП"/>
													<xs:enumeration value="РК"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:attribute>
									</xs:complexType>
								</xs:element>
								<xs:element name="Контент" type="КонтентТип">
									<xs:annotation>
										<xs:documentation>Содержимое файла</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:choice>
							<xs:sequence>
								<xs:element name="ПодписьВлож" type="ПодписьТип" minOccurs="0" maxOccurs="unbounded">
									<xs:annotation>
										<xs:documentation>Подпись и сведения о лице, подписывающем вложение</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:sequence>
						<xs:attribute name="КонтентИд" type="ГУИД32Тип">
							<xs:annotation>
								<xs:documentation>Уникальный идентификатор контента прикрепленного документа в ЕИС</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ВнешКонтентИд" type="ВнешИдТип">
							<xs:annotation>
								<xs:documentation>Внешний уникальный идентификатор контента прикрепленного документа </xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ИмяФайл" type="Строка1024Тип" use="required">
							<xs:annotation>
								<xs:documentation>Имя файла</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="РазмерФайл" type="РазмерФайлТип">
							<xs:annotation>
								<xs:documentation>Размер файла</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="Ссылка" type="СсылкаТип">
							<xs:annotation>
								<xs:documentation>Ссылка для скачивания прикрепленного документа. Игнорируется при приёме, заполняется при выгрузке</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="ПечатнФорм" type="ПечатнФормТип" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Печатная форма документа в HTML представлении</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:sequence>
			<xs:attribute name="ИдТрПакет" type="ГУИД36Тип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистОтпр" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы отправителя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистПол" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы получателя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдОбъект" type="ГУИД36Тип">
				<xs:annotation>
					<xs:documentation>Идентификатор цепочки документов.
При приеме в ЛКП игнорируется при приеме, заполняется идентификатором цепочки документов, присвоенным в ЕИС.
При приеме в ЛКЗ:
- если заполнен, то контролируется на соответствие идентификатору цепочки документов, который указан в связанном приложении к документу "УПД/УКД (титул продавца)",
- если не заполнен, то заполняется при передаче идентификатором цепочки документов, который указан в связанном приложении к документу "УПД/УКД (титул продавца)"</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ВнешИд" type="ВнешИдТип">
				<xs:annotation>
					<xs:documentation>Внешний идентификатор документа</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдФайл" type="ИдФайлТип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор файла, к которому сформировано приложение</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдПрилож" type="ИдФайлТип">
				<xs:annotation>
					<xs:documentation>Идентификатор приложения к документу</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="РеестрНомКонт" type="РеестрНомКонтТип">
				<xs:annotation>
					<xs:documentation>Реестровый номер контракта</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ДатаВрФормир" type="xs:dateTime" use="required">
				<xs:annotation>
					<xs:documentation>Дата-время формирования транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ТипПрилож" use="required">
				<xs:annotation>
					<xs:documentation>Тип приложенного документа:
- УПДПрод - УПД (титул продавца);
- УКДПрод - УКД (титул продавца);
- УПДПок - УПД (титул покупателя);
- УКДПок - УКД (титул покупателя);
- ИзвОшиб - Извещение об ошибке;
- КвитУспОбр - Квитанция об успешной обработке;
- УвУточ - Уведомлние об уточнении;
- ИзвУч - Извещение о принятии к учёту;
- ПодтвОтпр - Подтверждение даты отправки документа;
- ПодтвПолуч - Подтверждение даты получения документа;
- ИзвПол - Извещение о получении электронного документа;
- ПрОтз - Запрос об отзыве электронного документа;
- УвОбж - Уведомление о намерении обжаловать мотивированный отказ;
- КвитИзмСтатус - Квитанция об изменении статуса документа;
- АктСтройкаПрод - Акт по стройке (титул продавца);
- АктСтройкаПок - Акт по стройке (титул покупателя);
- УПДПродЗакрыт - УПД (титул продавца по сокрытому контракту);
- УКДПродЗакрыт - УКД (титул продавца по сокрытому контракту);
- УПДПокЗакрыт - УПД (титул покупателя по сокрытому контракту);
- УКДПокЗакрыт - УКД (титул покупателя по сокрытому контракту);
- УвУточЗакрыт - Уведомлние об уточнении (по сокрытому контракту);
- ИзвУчЗакрыт - Извещение о принятии к учёту (по сокрытому контракту);
- ПодтвОтпрЗакрыт - Подтверждение даты отправки документа (по сокрытому контракту);
- ПодтвПолучЗакрыт - Подтверждение даты получения документа (по сокрытому контракту);
- ИзвПолЗакрыт - Извещение о получении электронного документа (по сокрытому контракту);
- ПрОтзЗакрыт - Запрос об отзыве электронного документа (по сокрытому контракту);
- УвОбжЗакрыт - Уведомление о намерении обжаловать мотивированный отказ (по сокрытому контракту);
- КвитИзмСтатусЗакрыт - Квитанция об изменении статуса документа (по сокрытому контракту);
- АктСтройкаПродЗакрыт - Акт по стройке (титул продавца по сокрытому контракту);
- АктСтройкаПокЗакрыт - Акт по стройке (титул покупателя по сокрытому контракту)</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="УПДПрод"/>
						<xs:enumeration value="УКДПрод"/>
						<xs:enumeration value="УПДПок"/>
						<xs:enumeration value="УКДПок"/>
						<xs:enumeration value="ИзвОшиб"/>
						<xs:enumeration value="КвитУспОбр"/>
						<xs:enumeration value="УвУточ"/>
						<xs:enumeration value="ИзвУч"/>
						<xs:enumeration value="ПодтвОтпр"/>
						<xs:enumeration value="ПодтвПолуч"/>
						<xs:enumeration value="ИзвПол"/>
						<xs:enumeration value="ПрОтз"/>
						<xs:enumeration value="УвОбж"/>
						<xs:enumeration value="КвитИзмСтатус"/>
						<xs:enumeration value="АктСтройкаПрод"/>
						<xs:enumeration value="АктСтройкаПок"/>
						<xs:enumeration value="УПДПродЗакрыт"/>
						<xs:enumeration value="УКДПродЗакрыт"/>
						<xs:enumeration value="УПДПокЗакрыт"/>
						<xs:enumeration value="УКДПокЗакрыт"/>
						<xs:enumeration value="УвУточЗакрыт"/>
						<xs:enumeration value="ИзвУчЗакрыт"/>
						<xs:enumeration value="ПодтвОтпрЗакрыт"/>
						<xs:enumeration value="ПодтвПолучЗакрыт"/>
						<xs:enumeration value="ИзвПолЗакрыт"/>
						<xs:enumeration value="ПрОтзЗакрыт"/>
						<xs:enumeration value="УвОбжЗакрыт"/>
						<xs:enumeration value="КвитИзмСтатусЗакрыт"/>
						<xs:enumeration value="АктСтройкаПродЗакрыт"/>
						<xs:enumeration value="АктСтройкаПокЗакрыт"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="ВерсФорм" type="ВерсФормТип" use="required">
				<xs:annotation>
					<xs:documentation>Версия формата</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдОтпр" type="ИдУчТип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор участника документооборота, - отправителя файла обмена</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдПол" type="ИдУчТип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор участника документооборота, получателя файла обмена</xs:documentation>
				</xs:annotation>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="ФайлПакетДоп">
		<xs:annotation>
			<xs:documentation>Транспортный пакет для передачи дополнительного документа (сметы контракта)</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:any>
					<xs:annotation>
						<xs:documentation>Содержимое передаваемого документа</xs:documentation>
					</xs:annotation>
				</xs:any>
			</xs:sequence>
			<xs:attribute name="ИдТрПакет" type="ГУИД36Тип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистОтпр" type="Строка5Тип" use="required">
				<xs:annotation>
					<xs:documentation>Код системы отправителя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистПол" type="Строка5Тип" use="required">
				<xs:annotation>
					<xs:documentation>Код системы получателя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ДатаВрФормир" type="xs:dateTime" use="required">
				<xs:annotation>
					<xs:documentation>Дата-время формирования транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ТипОбъект" type="ТипОбъектТип" use="required">
				<xs:annotation>
					<xs:documentation>Тип объекта.
ФайлСметаКонт - смета контракта</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ИдОбъект" type="Строка100Тип">
				<xs:annotation>
					<xs:documentation>Идентификатор объекта.
При передаче сметы контракта указывается реестровый номер контракта</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ВерсФорм" type="ВерсФормТип" use="required">
				<xs:annotation>
					<xs:documentation>Версия формата</xs:documentation>
				</xs:annotation>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="ФайлЗапросРезул">
		<xs:annotation>
			<xs:documentation>Запрос результата обработки</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Документ">
					<xs:annotation>
						<xs:documentation>Состав и структура документа</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:attribute name="ИдТрПакет" type="ГУИД36Тип" use="required">
							<xs:annotation>
								<xs:documentation>Идентификатор переданного пакета</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
			<xs:attribute name="ИдФайл" type="ИдФайлТип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистОтпр" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы отправителя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистПол" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы получателя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ДатаВрФормир" type="xs:dateTime" use="required">
				<xs:annotation>
					<xs:documentation>Дата-время формирования транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ВерсПрог" use="required">
				<xs:annotation>
					<xs:documentation>Версия программы, с помощью которой сформирован файл</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="40"/>
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="ВерсФорм" type="ВерсФормТип" use="required">
				<xs:annotation>
					<xs:documentation>Версия формата</xs:documentation>
				</xs:annotation>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="ФайлРезул">
		<xs:annotation>
			<xs:documentation>Результат обработки</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Документ">
					<xs:annotation>
						<xs:documentation>Состав и структура документа</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="СведФайл">
								<xs:annotation>
									<xs:documentation>Сведения по обработанному пакету</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="ИдТрПакет" type="ГУИД36Тип" use="required">
										<xs:annotation>
											<xs:documentation>Идентификатор обработанного пакета данных</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ИдФайл">
										<xs:annotation>
											<xs:documentation>Имя файла</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:minLength value="1"/>
												<xs:maxLength value="150"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
									<xs:attribute name="ИдОбъект" type="ГУИД36Тип">
										<xs:annotation>
											<xs:documentation>Идентификатор объекта</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:choice>
								<xs:element name="УспешОбр">
									<xs:annotation>
										<xs:documentation>Успешная обработка</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:sequence minOccurs="0">
											<xs:element name="ПредупрежденияПр" minOccurs="0">
												<xs:annotation>
													<xs:documentation>Предупреждения, возникшие при проверке файла</xs:documentation>
												</xs:annotation>
												<xs:complexType>
													<xs:sequence>
														<xs:element name="ПредупреждениеПр" type="ОшибкаТип" maxOccurs="unbounded">
															<xs:annotation>
																<xs:documentation>Предупреждение</xs:documentation>
															</xs:annotation>
														</xs:element>
													</xs:sequence>
												</xs:complexType>
											</xs:element>
										</xs:sequence>
										<xs:attribute name="ИдОбъект" type="ГУИД36Тип" use="required">
											<xs:annotation>
												<xs:documentation>Идентификатор объекта (сквозной идентификатор цепочки документов)</xs:documentation>
											</xs:annotation>
										</xs:attribute>
										<xs:attribute name="ИдДокЕИС" type="ГУИД36Тип">
											<xs:annotation>
												<xs:documentation>Идентификатор документа в ЕИС</xs:documentation>
											</xs:annotation>
										</xs:attribute>
									</xs:complexType>
								</xs:element>
								<xs:element name="ОшибкиПр">
									<xs:annotation>
										<xs:documentation>Ошибки, возникшие при проверке файла</xs:documentation>
									</xs:annotation>
									<xs:complexType>
										<xs:sequence>
											<xs:element name="ОшибкаПр" type="ОшибкаТип" maxOccurs="unbounded">
												<xs:annotation>
													<xs:documentation>Ошибка</xs:documentation>
												</xs:annotation>
											</xs:element>
										</xs:sequence>
									</xs:complexType>
								</xs:element>
								<xs:element name="Процесс" type="xs:boolean" default="true">
									<xs:annotation>
										<xs:documentation>Данные обрабатываются</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:choice>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
			<xs:attribute name="ИдФайл" type="ИдФайлТип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистОтпр" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы отправителя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистПол" type="Строка5Тип">
				<xs:annotation>
					<xs:documentation>Код системы получателя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ДатаВрФормир" type="xs:dateTime" use="required">
				<xs:annotation>
					<xs:documentation>Дата-время формирования транспортного пакета</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ВерсПрог" use="required">
				<xs:annotation>
					<xs:documentation>Версия программы, с помощью которой сформирован файл</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="40"/>
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="ВерсФорм" type="ВерсФормТип" use="required">
				<xs:annotation>
					<xs:documentation>Версия формата</xs:documentation>
				</xs:annotation>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="ФайлКвитРезулПодписан">
		<xs:annotation>
			<xs:documentation>Квитанция с результатами подписания проекта документа</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Документ">
					<xs:annotation>
						<xs:documentation>Состав и структура документа</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:choice>
							<xs:element name="УспешПодписан">
								<xs:annotation>
									<xs:documentation>Успешное подписание</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="ПрУспешПодписан" type="xs:boolean" use="required" fixed="true">
										<xs:annotation>
											<xs:documentation>Признак успешного подписания</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="ОшибкиПодписан">
								<xs:annotation>
									<xs:documentation>Ошибки, возникшие при подписании</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="ОшибкаПр" type="ОшибкаТип" maxOccurs="unbounded">
											<xs:annotation>
												<xs:documentation>Ошибка</xs:documentation>
											</xs:annotation>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
						</xs:choice>
						<xs:attribute name="ВнешИдЗапрос" type="ГУИД36Тип" use="required">
							<xs:annotation>
								<xs:documentation>Внешний идентификатор запроса на подписание проекта документа</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ТипДокумент" use="required">
							<xs:annotation>
								<xs:documentation>Тип документа:
- УПДПрод - УПД (титул продавца);
- УКДПрод - УКД (титул продавца);
- УПДПок - УПД (титул покупателя);
- УКДПок - УКД (титул покупателя);
- УвУточ - Уведомлние об уточнении</xs:documentation>
							</xs:annotation>
							<xs:simpleType>
								<xs:restriction base="xs:string">
									<xs:enumeration value="УПДПрод"/>
									<xs:enumeration value="УКДПрод"/>
									<xs:enumeration value="УПДПок"/>
									<xs:enumeration value="УКДПок"/>
									<xs:enumeration value="УвУточ"/>
								</xs:restriction>
							</xs:simpleType>
						</xs:attribute>
						<xs:attribute name="ИдДокЕИС" type="ГУИД36Тип" use="required">
							<xs:annotation>
								<xs:documentation>Идентификатор документа (подписанного документа или проекта документа, попытка подписания которого завершилась ошибкой)</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
			<xs:attribute name="ИдФайл" type="ГУИД36Тип" use="required">
				<xs:annotation>
					<xs:documentation>Идентификатор квитанции</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистОтпр" type="Строка10Тип" use="required">
				<xs:annotation>
					<xs:documentation>Код системы отправителя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="СистПол" type="Строка10Тип" use="required">
				<xs:annotation>
					<xs:documentation>Код системы получателя</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ДатаВрФормир" type="xs:dateTime" use="required">
				<xs:annotation>
					<xs:documentation>Дата-время формирования квитанции</xs:documentation>
				</xs:annotation>
			</xs:attribute>
			<xs:attribute name="ВерсПрог" use="required">
				<xs:annotation>
					<xs:documentation>Версия программы, с помощью которой сформирован файл</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="40"/>
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="ВерсФорм" type="ВерсФормТип" use="required">
				<xs:annotation>
					<xs:documentation>Версия формата</xs:documentation>
				</xs:annotation>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:annotation>
		<xs:documentation>Элементы приложений к документам</xs:documentation>
	</xs:annotation>
	<xs:element name="ФайлУПДПрод">
		<xs:annotation>
			<xs:documentation>Приложение к титулу продавца УПД</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="СведКонт">
					<xs:annotation>
						<xs:documentation>Сведения о контракте</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:attribute name="РеестрНомКонт" type="РеестрНомКонтТип" use="required">
							<xs:annotation>
								<xs:documentation>Реестровый номер контракта</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ИдВерсКонт" type="xs:long" use="required">
							<xs:annotation>
								<xs:documentation>Идентификатор версии контракта, на основании которой сформирован УПД</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ИдЭтапКонт" type="ГУИД32Тип">
							<xs:annotation>
								<xs:documentation>GIUD этапа контракта</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ТехИдЭтапКонт" type="xs:long">
							<xs:annotation>
								<xs:documentation>Технический идентификатор этапа контракта.
Соответствует значению поля sid из сведений о контракте</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ВнешТехИдЭтапКонт" type="ВнешИдТип">
							<xs:annotation>
								<xs:documentation>Внешний технический идентификатор этапа контракта.
Соответствует значению поля externalSid из сведений о контракте</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ИКЗ" type="ИКЗТип">
							<xs:annotation>
								<xs:documentation>Идентификационный код закупки из контракта</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведПоставщик" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения о поставщике</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="ЮЛ" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Сведения о юридическом лице</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="КодСВР" type="КодСВРТип">
										<xs:annotation>
											<xs:documentation>Код СВР.
При приеме в сводном реестре организаций по сочетанию ИНН и КПП выполняется поиск актуальной записи:
- если запись найдена, то значение атрибута игнорируется при приеме, заполняется при передаче кодом СВР организации из сводного реестра организаций;
- если запись не найдена, то значение атрибута принимается из пакета, при этом контролируется обязательность заполнения</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ФирмНаимОрг" type="Строка1000Тип">
										<xs:annotation>
											<xs:documentation>Фирменное наименование.
Игнорируется при приеме, заполняется при передаче при наличии данных сведений в ЕРУЗ</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ПрКрКПП" type="xs:boolean">
										<xs:annotation>
											<xs:documentation>Признак использования КПП крупнейшего налогоплательщика.
Наличие данного признака со значением true означает, что в основном документе указан КПП крупнейшего налогоплательщика</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="БанкРеквКС" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Банковские реквизиты казначейского сопровождения.
Устарело, оставлено для обратной совместимости</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="ЛицСчетКС">
										<xs:annotation>
											<xs:documentation>Лицевой счет для казначейского сопровождения.
При приеме проверяется наличие лицевого счета для казначейского сопровождения в связанных сведениях о контракте:
- если в сведениях о контракте поле указано, то атрибут игнорируется при приеме, при передаче заполняется значением из сведений о контракте;
- если в сведениях о контракте поле не указано, то выполняется поиск лицевого счета для казначейского сопровождения в книге регистрации лицевых счетов. Если значение найдено, то атрибут игнорируется при приеме, при передаче заполняется найденным значением, иначе значение атрибута принимается из пакета, при этом контролируется обязательность заполнения</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:length value="11"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
									<xs:attribute name="БИК" type="БИКТип" use="required">
										<xs:annotation>
											<xs:documentation>Банковский идентификационный код (БИК)</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="НаимБанк" use="required">
										<xs:annotation>
											<xs:documentation>Наименование банка</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:minLength value="1"/>
												<xs:maxLength value="1000"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
									<xs:attribute name="КС" use="required">
										<xs:annotation>
											<xs:documentation>Казначейский счет</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:length value="20"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
									<xs:attribute name="ЕдинКС" use="required">
										<xs:annotation>
											<xs:documentation>Единый казначейский счет</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:string">
												<xs:length value="20"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="БанкРекв" type="БанкРеквТип" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Банковские реквизиты.

Блок обязателен для документов с функциями СЧФДОП и ДОП.
Блок необязателен для СЧФ.

В сосаве блока должен быть заполнен один из следующих атрибутов:

- "Тип счета" (ТипСчет). Наличие данного реквизита означает, что банковские реквизиты вводятся вручную. Все атрибуты блока принимаются в соответствии с правилами, указанным в описании данных реквизитов

- "Идентификатор платежных реквизитов поставщика из сведений о контракте" (ИдПлатежнРеквКонт). Наличие данного идентификатора означает то, что банковские реквизиты поставщика наследуются из сведений о контракте. Поиск в сведениях о контракте осуществляется по значению атрибута "Идентификатор платежных реквизитов поставщика из сведений о контракте" (ИдПлатежнРеквКонт). При указании данного атрибута следующие реквизиты игнорирются при приеме, заполняются автоматически из сведений о контракте:
- "ТипСчет" (ТипСчет);
- "Номер лицевого счета" (НомерЛицСчет);
- "Лицевой счет для казначейского сопровождения" (ЛицСчетКС);
- "Банковский идентификационный код (БИК)" (БИК);
- "Наименование банка" (НаимБанк);
- "Корреспондентский счет банка" (КорСчетБанк);
- "Расчетный счет" (РасчСчет);
- "Единый казначейский счет" (ЕдинКазнСчет);
- "Казначейский счет" (КазнСчет).
Остальные атрибуты блока принимаются в соответствии с правилами, указанным в описании данных реквизитов</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведКонтрагент" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения о контрагенте</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="ИдСв" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Идентификационные сведения.

Блок игнорируется при приеме проектов документов, заполняется в ЕИС в соответствии с выбранными платежными реквизитами из сведений о контракте</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:choice>
										<xs:element name="СвИП">
											<xs:annotation>
												<xs:documentation>Сведения об индивидуальном предпринимателе</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="ФИО" type="ФИОТип">
														<xs:annotation>
															<xs:documentation>Фамилия, имя, отчество (при наличии)</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
												<xs:attribute name="ИННФЛ" type="ИННФЛТип" use="required">
													<xs:annotation>
														<xs:documentation>ИНН физического лица</xs:documentation>
													</xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
										<xs:element name="СвЮЛУч">
											<xs:annotation>
												<xs:documentation>Сведения об организации, состоящей на учете в налоговых органах</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:attribute name="НаимОрг" use="required">
													<xs:annotation>
														<xs:documentation>Наименование полное</xs:documentation>
													</xs:annotation>
													<xs:simpleType>
														<xs:restriction base="xs:string">
															<xs:minLength value="1"/>
															<xs:maxLength value="1000"/>
														</xs:restriction>
													</xs:simpleType>
												</xs:attribute>
												<xs:attribute name="ИННЮЛ" type="ИННЮЛТип" use="required">
													<xs:annotation>
														<xs:documentation>ИНН юридического лица</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="КПП" type="КППТип" use="optional">
													<xs:annotation>
														<xs:documentation>Код причины постановки на учет (далее – КПП)</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ПрКрКПП" type="xs:boolean" use="optional">
													<xs:annotation>
														<xs:documentation>Признак использования КПП крупнейшего налогоплательщика.
Наличие данного признака со значением true означает, что в основном документе указан КПП крупнейшего налогоплательщика</xs:documentation>
													</xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
										<xs:element name="СвФЛУч">
											<xs:annotation>
												<!---************************************************************************************************************************************************************-->
												<xs:appinfo>
													<sch:pattern name="Проверка обязательности присутствия элемента ИННФЛ в зависимости от значения элемента ИдСтатЛ и присутствия элементов ИныеСвед и ФИО">
														<sch:rule context="СвФЛУч">
															<sch:assert test="usch:iif(
												(@ИдСтатЛ)!=0 and count(@ИныеСвед)=0 and count(ФИО)=0 , 
												count(@ИННФЛ)!=0, 
												count(@ИННФЛ)=0 or count(@ИННФЛ)!=0
												)">
																<usch:error code="0400300003" path="@ИННФЛ" value-of-select="count(@ИННФЛ)">Не выполнено условие присутствия элемента ИННФЛ при значении элемента ИдСтатЛ равном "<usch:value-of select="@ИдСтатЛ"/>" и присутствии элемента ИныеСвед в количестве, равном "<usch:value-of select="count(@ИныеСвед)"/>" и присутствии элемента ФИО в количестве, равном "<usch:value-of select="count(ФИО)"/>"                                 .
													</usch:error>
															</sch:assert>
														</sch:rule>
													</sch:pattern>
												</xs:appinfo>
												<!---*************************************************************************************************************************************************************-->
												<!---************************************************************************************************************************************************************-->
												<xs:appinfo>
													<sch:pattern name="Проверка обязательности присутствия элемента ИныеСвед в зависимости от значения элемента ИдСтатЛ и присутствия элемент ФИО">
														<sch:rule context="СвФЛУч">
															<sch:assert test="usch:iif(
												(@ИдСтатЛ)!=0 and count(ФИО)=0 , 
												count(@ИныеСвед)!=0, 
												count(@ИныеСвед)=0 or count(@ИныеСвед)!=0
												)">
																<usch:error code="0400300003" path="@ИныеСвед" value-of-select="count(@ИныеСвед)">Не выполнено условие присутствия элемента ИныеСвед при значении элемента ИдСтатЛ равном "<usch:value-of select="@ИдСтатЛ"/>" и присутствии элемента ФИО в количестве, равном "<usch:value-of select="count(ФИО)"/>"                                 .
													</usch:error>
															</sch:assert>
														</sch:rule>
													</sch:pattern>
												</xs:appinfo>
												<!---*************************************************************************************************************************************************************-->
												<!---************************************************************************************************************************************************************-->
												<xs:appinfo>
													<sch:pattern name="Проверка обязательности присутствия элемента ФИО в зависимости от значения элемента ИдСтатЛ и присутствия элементов ИННФЛ и ИныеСвед">
														<sch:rule context="СвФЛУч">
															<sch:assert test="usch:iif(
												(@ИдСтатЛ)!=0 and count(@ИННФЛ)=0 and count(@ИныеСвед)=0 , 
												count(ФИО)!=0, 
												count(ФИО)=0 or count(ФИО)!=0
												)">
																<usch:error code="0400300003" path="ФИО" value-of-select="count(ФИО)">Не выполнено условие присутствия элемента ФИО при значении элемента ИдСтатЛ равном "<usch:value-of select="@ИдСтатЛ"/>" и присутствии элемента ИННФЛ в количестве, равном "<usch:value-of select="count(@ИННФЛ)"/>" и присутствии элемента ИныеСвед в количестве, равном "<usch:value-of select="count(@ИныеСвед)"/>"                                 .
													</usch:error>
															</sch:assert>
														</sch:rule>
													</sch:pattern>
												</xs:appinfo>
												<!---*************************************************************************************************************************************************************-->
												<xs:documentation>Сведения о физическом лице</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="ФИО" type="ФИОТип" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Фамилия, имя, отчество (при наличии)</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
												<xs:attribute name="ИННФЛ" type="ИННФЛТип" use="optional">
													<xs:annotation>
														<xs:documentation>ИНН физического лица</xs:documentation>
													</xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
									</xs:choice>
								</xs:complexType>
							</xs:element>
							<xs:element name="БанкРекв" type="БанкРеквТип">
								<xs:annotation>
									<xs:documentation>Банковские реквизиты.
При приеме проекта документа проверяется, что атрибут "Идентификатор платежных реквизитов поставщика из сведений о контракте" (ИдПлатежнРеквКонт) заполнен корректным идентификатором из сведений о контракте.

Другие дочерние атрибуты и блоки игнорируются и заполняются в соответствии с контрактом</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведЗаказчик" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения о заказчике</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:attribute name="КодСВР" type="КодСВРТип">
							<xs:annotation>
								<xs:documentation>Код СВР.
Игнорируется при приеме, заполняется при передаче кодом СВР из сводного реестра организаций</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ЗаказчикВключГрузПолуч" type="xs:boolean">
							<xs:annotation>
								<xs:documentation>Заказчик включен в список грузполучателей.
Атрибут может быть заполнен только в том случае, если для заказчика указано хотя бы одно место поставки</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведТов" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения об отгруженных товарах (о выполненных работах, оказанных услугах), переданных имущественных правах</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="СведТРУ" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Сведения о товарах, работах, услугах (ТРУ).
Если отраслевой специализацией документа является сторительство и установлен признак накопительного итога (в атибуте "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог) указано значение true), то данный блок игнорируется при приеме, заполняется автоматически при передаче на основании сметы контракта и значений, полученных в блоке "Сведения о товарах, работах, услугах (ТРУ) в соответствии со сметой контракта" (ФайлУПДПрод/СведТов/СведТРУСметаКонт), который в данном случае обязателен при приеме.
В других случаях контролируется обязательность заполнения блока</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:choice>
										<xs:element name="НедеталТРУ">
											<xs:annotation>
												<xs:documentation>Сведения о позиции ТРУ.
В блоке указываются недетализированные позиции ТРУ из сведений о контракте (у которых отсутствуют соподчиненные позиции) или соподчиненные позиции ТРУ из сведений о контракте.
При приеме контролируется недопустимость указания позиции ТРУ из сведений о контракте, у которой есть соподчиненные позиции</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:choice>
													<xs:element name="НеЛПСвед" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>Сведения об объекте закупки в том случае, когда объектом закупки является не лекарственный препарат.

В составе блока одна и та же позиция из сведений о контракте может быть указана более одного раза (за исключением позиций с типом "Работа"). При этом для таких позиций должно быть уникально значение идентификатора, задаваемого в атрибуте "GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования (сметы контракта)" (ЭАИдТРУ)</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="СтранаПроисх" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране происхождения товара.
Игнорируется при приеме авансовых СЧФ.
В других случаях принимается только в том случае, если позиция является товаром</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СтранаПроизв" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране регистрации производителя товара.
Игнорируется при приеме авансовых СЧФ.
Игнорируется при приеме, если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях принимается только в том случае, если позиция является товаром</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ОтрСпец" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения ТРУ, относящиеся к отраслевой специализации</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:choice>
																			<xs:element name="СтройДетал" type="СтройДеталУПДПродТип">
																				<xs:annotation>
																					<xs:documentation>Детализация полей ТРУ, относящихся к отраслевой специализации "Строительство".
Блок может быть задан только в том случае, если задан атрибут «Отраслевая специализация» (ФайлУПДПрод/СведТов/@ОтрСпец) заполнен значением 1 - "Строительство".
В составе блока должен быть заполнен как минимум один блок "Раздел видов работ" (Раздел) и/или как минимум один блок "Конструктивное решение (вид работ) (УПД)" (ВидРаб)</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																			<xs:element name="ПриобЖилПомДетал">
																				<xs:annotation>
																					<xs:documentation>Детализация полей ТРУ, относящихся к отраслевой специализации "Приобретение жилых помещений".
Блок может быть задан только в том случае, если:
1. задан атрибут «Отраслевая специализация» (ФайлУПДПрод/СведТов/@ОтрСпец) заполнен значением 3 - "Приобретение жилых помещений";
2. для документа УПД в атрибуте "Функция" (Файл/Документ/@Функция) НЕ задано значение "СЧФ"</xs:documentation>
																				</xs:annotation>
																				<xs:complexType>
																					<xs:sequence>
																						<xs:element name="СведЖилПом">
																							<xs:annotation>
																								<xs:documentation>Сведения о жилом помещении</xs:documentation>
																							</xs:annotation>
																							<xs:complexType>
																								<xs:attribute name="ТипЖилПом" use="required">
																									<xs:annotation>
																										<xs:documentation>Тип помещения.
Допустимо указание одного из значений:
1 - Однокомнатная квартира
2 - Двухкомнатная квартира
3 - Трехкомнатная квартира
0 - Другое</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="xs:string">
																											<xs:enumeration value="0"/>
																											<xs:enumeration value="1"/>
																											<xs:enumeration value="2"/>
																											<xs:enumeration value="3"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="ТипЖилПомТекст">
																									<xs:annotation>
																										<xs:documentation>Тип помещения, ручной ввод.
Принимается только в том случае, если в поле "Тип помещения" (ТипЖилПом) указано значение "0".
В других случаях игнорируется при приеме, не заполняется</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка100Тип">
																											<xs:pattern value="[а-яА-ЯёЁ/./,/ -]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="ОписаниеЖилПом" use="required">
																									<xs:annotation>
																										<xs:documentation>Характеристика/описание жилого помещения</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка2000Тип">
																											<xs:pattern value='[а-яА-ЯёЁ0-9,.№;:—_"“”«»()\\`’„“‘’‚’/ ///-]{1,}'/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="АдресТекст" use="required">
																									<xs:annotation>
																										<xs:documentation>Адрес жилого помещения</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка1000Тип">
																											<xs:pattern value="[а-яА-ЯёЁ0-9/./,/ //-]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="КадастрНомерЖилПом" use="required">
																									<xs:annotation>
																										<xs:documentation>Кадастровый (или условный) номер жилого помещения</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="xs:string">
																											<xs:minLength value="1"/>
																											<xs:maxLength value="19"/>
																											<xs:pattern value="[0-9://]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="РаспрДолей">
																									<xs:annotation>
																										<xs:documentation>Распределение долей владения</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка2000Тип">
																											<xs:pattern value="[а-яА-ЯёЁ0-9/./,/ //-]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																							</xs:complexType>
																						</xs:element>
																						<xs:element name="ПравоСобствДок" minOccurs="0">
																							<xs:annotation>
																								<xs:documentation>Документ, подтверждающий право собственности</xs:documentation>
																							</xs:annotation>
																							<xs:complexType>
																								<xs:attribute name="ПравоСобствТекст">
																									<xs:annotation>
																										<xs:documentation>Вид, номер и дата документа, подтверждающего право собственности.

Пример: Собственность, № 12-АБ 345678 от 01.01.2023</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка100Тип">
																											<xs:pattern value="[а-яА-ЯёЁ0-9/./,/ /№-]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="ИныеСвед" type="Строка2000Тип" use="optional">
																									<xs:annotation>
																										<xs:documentation>Дополнительные сведения</xs:documentation>
																									</xs:annotation>
																								</xs:attribute>
																							</xs:complexType>
																						</xs:element>
																						<xs:element name="Застройщик" minOccurs="0">
																							<xs:annotation>
																								<xs:documentation>Информация застройщика</xs:documentation>
																							</xs:annotation>
																							<xs:complexType>
																								<xs:attribute name="КадастрНомер" use="required">
																									<xs:annotation>
																										<xs:documentation>Кадастровый номер земельного участка</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="xs:string">
																											<xs:minLength value="1"/>
																											<xs:maxLength value="19"/>
																											<xs:pattern value="[0-9://]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="РазрВводОбъектНомер">
																									<xs:annotation>
																										<xs:documentation>Регистрационный номер и дата выдачи Разрешения на ввод объекта в эксплуатацию.

Пример: 12-345678-901-2023, 01.01.2023</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="xs:string">
																											<xs:minLength value="1"/>
																											<xs:maxLength value="30"/>
																											<xs:pattern value="[0-9/./,/ -]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																								<xs:attribute name="АдресТекст">
																									<xs:annotation>
																										<xs:documentation>Строительный адрес.

Пример: 123456, Саратовская обл., г. Саратов, ул. Лесная, д.24, корп.2</xs:documentation>
																									</xs:annotation>
																									<xs:simpleType>
																										<xs:restriction base="Строка1000Тип">
																											<xs:pattern value="[а-яА-ЯёЁ0-9/./,/ //-]{1,}"/>
																										</xs:restriction>
																									</xs:simpleType>
																								</xs:attribute>
																							</xs:complexType>
																						</xs:element>
																					</xs:sequence>
																				</xs:complexType>
																			</xs:element>
																		</xs:choice>
																	</xs:complexType>
																</xs:element>
																<xs:element name="СведПоставкиТов" type="СведПоставкиТип" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<xs:documentation>Сведения о месте поставки.
Принимается только в том случае, если одновременно выполняются следующие условия:
 - документ не является счет-фактурой; 
 - документ не содержит специализацию "Строительство" или "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) не заполнен значением "1" или "3".
В других случаях игнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ВыпНачПериод" type="ВыпПериодСтоимСНДСТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Игнорируется при приеме, рассчитывается автоматически и заполняется при передаче, если задан атрибут "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог)</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="КолИлиОбСмета" type="КоличИлиОбъемТекстТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Количество или объем работы по смете.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ЗамененТРУ" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Информация о заменной позиции ТРУ.

Блок заполняется в том случае, если позиция была заменена.

В составе блока указывается идентификатор замененой позиции.

Блок принимается только в том случае, если одновременно выполняются следующие условия:
1. принимаемый документ является исправлением
2. функция документа отлична от СЧФ;
3. не установлен признак "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог)

До версии 13.0 недетализированная позиция идентифицировалось по идентификаторам из сведений о контракте (ИдТРУ, ТехИдТРУ, ВнешИдТРУ), поэтому при формировании исправления к документу, подписанному до выхода версии ЕИС 13.0, в качестве идентификатора замененной позиции требуется указывать атрибут "GUID товара, работы, услуги из сведений о контракте" (КонтрактИдТРУ).

В других случаях требуется указывать атрибут "GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования" (ЭАИдТРУ)</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:choice>
																			<xs:element name="ЭАИдТРУ" type="ГУИД32Тип">
																				<xs:annotation>
																					<xs:documentation>GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																			<xs:element name="КонтрактИдТРУ" type="ГУИД32Тип">
																				<xs:annotation>
																					<xs:documentation>GUID товара, работы, услуги из сведений о контракте</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																		</xs:choice>
																	</xs:complexType>
																</xs:element>
																<xs:element name="НомСредИдентТов" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<!---************************************************************************************************************************************************************-->
																		<xs:appinfo>
																			<sch:pattern name="Проверка обязательности присутствия элемента ИдентТрансУпак в зависимости от присутствия элементов КИЗ, КолВедМарк и НомУпак">
																				<sch:rule context="НомСредИдентТов">
																					<sch:assert test="usch:iif(
																					
												count(КИЗ)=0 and count(@КолВедМарк)=0 and count(НомУпак)=0 , 
												count(@ИдентТрансУпак)!=0, 
												count(@ИдентТрансУпак)=0 or count(@ИдентТрансУпак)!=0
												)">
																						<usch:error code="0400300003" path="@ИдентТрансУпак" value-of-select="count(@ИдентТрансУпак)">Не выполнено условие присутствия элемента ИдентТрансУпак при присутствии элемента КИЗ в количестве, равном "<usch:value-of select="count(КИЗ)"/>" и при присутствии элемента КолВедМарк в количестве, равном "<usch:value-of select="count(@КолВедМарк)"/>" и присутствии элемента НомУпак в количестве, равном "<usch:value-of select="count(НомУпак)"/>"/>"                                 .
													</usch:error>
																					</sch:assert>
																				</sch:rule>
																			</sch:pattern>
																		</xs:appinfo>
																		<!---*************************************************************************************************************************************************************-->
																		<!---************************************************************************************************************************************************************-->
																		<xs:appinfo>
																			<sch:pattern name="Проверка обязательности присутствия элемента КолВедМарк в зависимости от присутствия элементов КИЗ, НомУпак и ИдентТрансУпак">
																				<sch:rule context="НомСредИдентТов">
																					<sch:assert test="usch:iif(
												count(КИЗ)=0 and count(НомУпак)=0 and count(@ИдентТрансУпак)=0 , 
												count(@КолВедМарк)!=0, 
												count(@КолВедМарк)=0 or count(@КолВедМарк)!=0
												)">
																						<usch:error code="0400300003" path="@КолВедМарк" value-of-select="count(@КолВедМарк)">Не выполнено условие присутствия элемента КолВедМарк при присутствии элемента КИЗ в количестве, равном "<usch:value-of select="count(КИЗ)"/>" и присутствии элемента НомУпак в количестве, равном "<usch:value-of select="count(НомУпак)"/>" и присутствии элемента ИдентТрансУпак в количестве, равном "<usch:value-of select="count(@ИдентТрансУпак)"/>"                                 .
													</usch:error>
																					</sch:assert>
																				</sch:rule>
																			</sch:pattern>
																		</xs:appinfo>
																		<!---*************************************************************************************************************************************************************-->
																		<!---************************************************************************************************************************************************************-->
																		<xs:appinfo>
																			<sch:pattern name="Проверка обязательности присутствия элемента КИЗ в зависимости от присутствия элементов КолВедМарк, НомУпак и ИдентТрансУпак">
																				<sch:rule context="НомСредИдентТов">
																					<sch:assert test="usch:iif(
												count(@КолВедМарк)=0 and count(НомУпак)=0 and count(@ИдентТрансУпак)=0 , 
												count(КИЗ)!=0, 
												count(КИЗ)=0 or count(КИЗ)!=0
												)">
																						<usch:error code="0400300003" path="@КИЗ" value-of-select="count(КИЗ)">Не выполнено условие присутствия элемента КИЗ при присутствии элемента КолВедМарк в количестве, равном "<usch:value-of select="count(@КолВедМарк)"/>" и присутствии элемента НомУпак в количестве, равном "<usch:value-of select="count(НомУпак)"/>" и присутствии элемента ИдентТрансУпак в количестве, равном "<usch:value-of select="count(@ИдентТрансУпак)"/>"                                 .
													</usch:error>
																					</sch:assert>
																				</sch:rule>
																			</sch:pattern>
																		</xs:appinfo>
																		<!---*************************************************************************************************************************************************************-->
																		<!---************************************************************************************************************************************************************-->
																		<xs:appinfo>
																			<sch:pattern name="Проверка обязательности присутствия элемента НомУпак в зависимости от присутствия элементов КолВедМарк, КИЗ и ИдентТрансУпак">
																				<sch:rule context="НомСредИдентТов">
																					<sch:assert test="usch:iif(
												count(@КолВедМарк)=0 and count(КИЗ)=0 and count(@ИдентТрансУпак)=0 , 
												count(НомУпак)!=0, 
												count(НомУпак)=0 or count(НомУпак)!=0
												)">
																						<usch:error code="0400300003" path="@НомУпак" value-of-select="count(НомУпак)">Не выполнено условие присутствия элемента НомУпак при присутствии элемента КолВедМарк в количестве, равном "<usch:value-of select="count(@КолВедМарк)"/>" и присутствии элемента КИЗ в количестве, равном "<usch:value-of select="count(КИЗ)"/>" и присутствии элемента ИдентТрансУпак в количестве, равном "<usch:value-of select="count(@ИдентТрансУпак)"/>"                                 .
													</usch:error>
																					</sch:assert>
																				</sch:rule>
																			</sch:pattern>
																		</xs:appinfo>
																		<!---*************************************************************************************************************************************************************-->
																		<xs:documentation>Номер средств идентификации товаров

Блок заполняется при размещении. Не используется при приеме по интеграции</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:choice>
																			<xs:element name="КИЗ" minOccurs="0" maxOccurs="unbounded">
																				<xs:annotation>
																					<xs:documentation>Контрольный идентификационный знак</xs:documentation>
																				</xs:annotation>
																				<xs:simpleType>
																					<xs:restriction base="xs:string">
																						<xs:minLength value="1"/>
																						<xs:maxLength value="255"/>
																					</xs:restriction>
																				</xs:simpleType>
																			</xs:element>
																			<xs:element name="НомУпак" minOccurs="0" maxOccurs="unbounded">
																				<xs:annotation>
																					<xs:documentation>Уникальный идентификатор вторичной (потребительской)/третичной (заводской, транспортной) упаковки</xs:documentation>
																				</xs:annotation>
																				<xs:simpleType>
																					<xs:restriction base="xs:string">
																						<xs:minLength value="1"/>
																						<xs:maxLength value="255"/>
																					</xs:restriction>
																				</xs:simpleType>
																			</xs:element>
																		</xs:choice>
																		<xs:attribute name="ИдентТрансУпак" type="xs:string" use="optional">
																			<xs:annotation>
																				<xs:documentation>Уникальный идентификатор транспортной упаковки</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КолВедМарк" use="optional">
																			<xs:annotation>
																				<xs:documentation>Количество товара в единицах измерения маркированного товара средствами идентификации</xs:documentation>
																			</xs:annotation>
																			<xs:simpleType>
																				<xs:restriction base="xs:integer">
																					<xs:totalDigits value="26"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:attribute>
																		<xs:attribute name="ПрПартМарк" use="optional">
																			<xs:annotation>
																				<xs:documentation>Производственная партия (КОД)</xs:documentation>
																			</xs:annotation>
																			<xs:simpleType>
																				<xs:restriction base="xs:string">
																					<xs:minLength value="1"/>
																					<xs:maxLength value="55"/>
																				</xs:restriction>
																			</xs:simpleType>
																		</xs:attribute>
																		<xs:attribute name="ИдентДокПост" type="Строка20Тип">
																			<xs:annotation>
																				<xs:documentation>Идентификатор документа поставки</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="НаимНомДатаДокПост" type="Строка1000Тип">
																			<xs:annotation>
																				<xs:documentation>Наименование, номер, дата документа поставки</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="НомСтр" type="Число6Тип">
																<xs:annotation>
																	<xs:documentation>Номер строки таблицы. Требуется обязательное заполнение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЭАИдТРУ" type="ГУИД32Тип">
																<xs:annotation>
																	<xs:documentation>GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования.

При передаче из внешней системы значение должно генерироваться отправляющей стороной.

При приеме контролируется обязательность заполнения и уникальность в рамках документа электронного актирования</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ОбРабУсл" type="Строка500Тип">
																<xs:annotation>
																	<xs:documentation>Объем работы, услуги в текстовом выражении.
Контролируется обязательное заполнение данного атрибута или атрибута "Количество (объем) (графа 3 счета-фактуры)" (Файл/Документ/ТаблСчФакт/СведТов/@КолТов), указываемого в составе основого документа</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЦенаИзКонтСНДС" type="ЧислоМакс15ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Цена за единицу с НДС (из сведений контракта).
Игнорируется при приеме, если:
- документ формируется к контракту для оказание финансовых услуг по открытию и ведению расчетных счетов (цена контракта 0);
- при приеме авансовых СЧФ.
В других случаях обязателен для заполнения.

Для документов, формируемых по контракту с установленным признаком заключения по цене за право, необходимо указывать значение "0.00".
В других случаях, если одновременно выполняются следующие условия, то цена за единицу может быть изменена относительно цены, указанной в связанном контракте:
- в связанном контракте в поле "Способ указания цены контракта" (priceInfo/priceType) установлено значение "MP" (Максимальное значение цены контракта);
- в связанном контракте указан один из следующих кодов ОКПД2:
19.20;
06.20.10.131;
65.11.10.110;
65.12.11.000;
65.12.12.000;
65.12.21.000;
65.12.34.000;
65.12.41.000;
65.12.49.000;
65.12.50.000;
65.12.90.000;
06.20.10.110.
Иначе цена должна быть указана в соответствии с ценой, заданной для данного объекта закупки в связанном контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СтоимСметаСНДС" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Стоимость из сметы контракта с НДС.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СтоимСметаБезНДС" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Стоимость из сметы контракта без НДС.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПозСмет" type="Строка100Тип">
																<xs:annotation>
																	<xs:documentation>Номер позиции по смете. Если значение атрибута "Отраслевая специализация" (ФайлУПДПрод/СведТов/@ОтрСпец) не равно 1 - "Строительство", то атрибут игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПрУлучшХаракт">
																<xs:annotation>
																	<xs:documentation>Признак поставки объекта закупки с улучшенными характеристиками:
- 1 - не установлен;
- 2 - установлен из информации о контракте;
- 3 - установлен пользователем.
Игнорируется для авансовых СЧФ.
Игнорируется при приеме, если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
Игнорируется при приеме исправления к документу, который был подписан до версии 11.2.
В других случаях контролируется обязательное заполнение.
Если для позиции ТРУ в сведениях о контракте установлен одноименный признак, то контролируется, что в составе данного атрибута указано значение "2 - установлен из информации о контракте".
Если для позиции ТРУ в сведениях о контракте НЕ установлен одноименный признак, то контролируется, что в составе данного атрибута указано значение, отличное от "2 - установлен из информации о контракте".
В исправлении редактирование данного признака допускается только в том случае, если:
- статус документа, к которому формируется исправление - «Отказано при рассмотрении»
- в сведениях о контракте для данной позиции не установлен признак поставки объекта закупки с улучшенными характеристиками</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:enumeration value="1"/>
																		<xs:enumeration value="2"/>
																		<xs:enumeration value="3"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:attribute>
															<xs:attribute name="СведЖилПом" type="Строка10000Тип">
																<xs:annotation>
																	<xs:documentation>Сведения о характеристиках жилого помещения.
Атрибут обязателен для заполнения, если документ содержит специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="АктирЗаверш" type="xs:boolean">
																<xs:annotation>
																	<xs:documentation>Актирование по позиции завершено.

Наличие данного атрибута со значением "true" означает, что актирование по данной позиции из сведений о контракте завершено.

Указание допускается только в следующих случаях:
- документ не является авансовой СЧФ;
- в связанном контракте не установлен признак "Невозможно указать сведения о количестве товара, работы, услуги" (products/quantityUndefined);
- в связанном контракте не заполнен блок "Цена за право заключения контракта" (priceInfo/rightToConcludeContractPriceInfo);
- в основном документе для позиции заполнен атрибут "Количество (объем) (графа 3 счета-фактуры)" (Файл/Документ/ТаблСчФакт/СведТов/@КолТов);
- одновременно не выполняются следующие условия:
	- в связанном контракте в поле "Способ указания цены контракта" (priceInfo/priceType) установлено значение "MP" (Максимальное значение цены контракта);
	- в связанном контракте заполнено поле "Формула указания цены контракта" (priceInfo/priceFormula);
	- код по ОКПД2 для текущего объекта закупки содержится в перечне кодов:
	19.20;
	06.20.10.131;
	65.11.10.110;
	65.12.11.000;
	65.12.12.000;
	65.12.21.000;
	65.12.34.000;
	65.12.41.000;
	65.12.49.000;
	65.12.50.000;
	65.12.90.000;
	06.20.10.110.

Если передается несолько позиций, сформированных по одной позиции из сведений о контракте, то данный признак может быть задан только для одной позиции.

В других случаях атрибут игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ОстаточнСтоим" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Остаточная стоимость по позиции (разница между стоимостью из контракта и заактированной стоимостью).

Игнорируется при приеме, рассчитывается автоматически</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
													<xs:element name="ЛПСвед" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>Сведения об объекте закупки в том случае, когда объектом закупки является лекарственный препарат</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="ПозицПоМНН">
																	<xs:annotation>
																		<xs:documentation>Позиция по торговому наименованию лекарственного средства</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:attribute name="МНН" type="Строка2000Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Международное непатентованное или химическое или группировочное наименование</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="ТН" type="Строка500Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Торговое наименование</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="ЛекФорм" type="Строка500Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Лекарственная форма</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="Доз" type="Строка500Тип">
																			<xs:annotation>
																				<xs:documentation>Дозировка.
Устарело, оставлено для обратной совместимости</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="ДозСвед" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о дозировке.
Контролируется обязательность заполнения при приеме</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:attribute name="Наим" type="Строка500Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Наименование</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="Знач" type="ЧислоМакс10ДоТочкТип" use="required">
																			<xs:annotation>
																				<xs:documentation>Значение</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="ПотребЕдИзмСвед" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о потребительской единице измерения.
Игнорируется при приеме для авансовых СЧФ, в других случаях контролируется обязательность заполнения при приеме</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:sequence minOccurs="0">
																			<xs:element name="ОКЕИ" type="ОКЕИТип" minOccurs="0">
																				<xs:annotation>
																					<xs:documentation>Единица измерения по ОКЕИ</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																		</xs:sequence>
																		<xs:attribute name="Наим" type="Строка500Тип">
																			<xs:annotation>
																				<xs:documentation>Наименование потребительской единицы измерения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="Колич" type="ЧислоМакс15ДоТочкТип" use="required">
																			<xs:annotation>
																				<xs:documentation>Количество в потребительских единицах измерения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="УпакСвед">
																	<xs:annotation>
																		<xs:documentation>Сведения об упаковке</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:attribute name="ВидПервУпак" type="Строка500Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Вид первичной упаковки</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КомплПотребУпак" type="Строка500Тип">
																			<xs:annotation>
																				<xs:documentation>Комплектность потребительской упаковки</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КоличЛекФормВПервУпак" type="ЧислоМакс11ДоТочкТип" use="required">
																			<xs:annotation>
																				<xs:documentation>Количество лекарственных форм в первичной упаковке</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КоличПервУпакВПотребУпак" type="Число11Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Количество первичных упаковок в потребительской упаковке</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КоличЛекФормВПотребУпак" type="ЧислоМакс22ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Количество лекарственных форм в потребительской упаковке.
Устрарело, не применяется. Игнорируется при приёме</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="КоличПотребЕдВПотребУпак" type="ЧислоМакс21ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Количество потребительских единиц в потребительской упаковке. С версии 10.3 требуется обязательное заполнение атрибута</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="СтранаПроисх" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране происхождения товара</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СтранаПроизв" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Страна производителя</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ЖНВЛП" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Признак включения в реестр жизненно необходимых и важнейших лекарственных препаратов.
Указание блока означает, что установлен признак включения в реестр ЖНВЛП. При этом содержимое блока может быть не заполнено для авансовых СЧФ</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:attribute name="ФактОтпЦена" type="ЧислоМакс18ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Фактическая отпускная цена ЛП, руб.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="ЗарегПредОтпЦена" type="ЧислоМакс18ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Зарегистрированная предельная отпускная цена ЛП, руб.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="СуммРазмФактОптНадбРуб" type="ЧислоМакс18ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Суммарный размер фактических оптовых надбавок ЛП, руб.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																		<xs:attribute name="СуммРазмФактОптНадбПроц" type="ЧислоМакс18ДоТочкТип">
																			<xs:annotation>
																				<xs:documentation>Суммарный размер фактических оптовых надбавок (процент) ЛП, %.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="СведПоставкиТов" type="СведПоставкиТовТип" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<xs:documentation>Сведения о месте поставки.
Принимается только в том случае, если документ не является счет-фактурой</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ЗамененТРУ" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Информация о заменной позиции ТРУ.

Блок заполняется в том случае, если позиция была заменена.

В составе блока указывается идентификатор замененой позиции с ЛП.

Блок принимается только в том случае, если одновременно выполняются следующие условия:
1. принимаемый документ является исправлением
2. функция документа отлична от СЧФ;
3. не установлен признак "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог)</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:attribute name="ИдЛП" type="ГУИД32Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Идентификатор лекарственного препарата</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="НомСтр" type="Число6Тип">
																<xs:annotation>
																	<xs:documentation>Номер строки таблицы. Требуется обязательное заполнение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ИдЛП" type="ГУИД32Тип">
																<xs:annotation>
																	<xs:documentation>Идентификатор лекарственного препарата. Требуется обязательное заполнение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЦенаЗаУпакСНДС" type="ЧислоМакс15ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Цена за потребительскую упаковку (с НДС).
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СерияЛекПреп" type="Строка50Тип">
																<xs:annotation>
																	<xs:documentation>Серия ЛП.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СрокГодн" type="ДатаТип">
																<xs:annotation>
																	<xs:documentation>Срок годности ЛП.
Не заполняется для авансовых СЧФ, в других случаях обязателен для заполнения</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="АктирЗаверш" type="xs:boolean">
																<xs:annotation>
																	<xs:documentation>Актирование по позиции завершено.

Наличие данного атрибута со значением "true" означает, что актирование по данной позиции из сведений о контракте завершено.

Допускается указание, если документ не является авансовой СЧФ.

Если в составе документа указано несколько ЛП, сформированных по одной позиции из сведений о контракте, то данный признак может быть задан только для одной из передаваемых позиций ЛП.

В других случаях атрибут игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ОстаточнСтоим" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Остаточная стоимость по позиции (разница между стоимостью из контракта и заактированной стоимостью).

Игнорируется при приеме, рассчитывается автоматически</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
												</xs:choice>
												<xs:attribute name="НомСтр" type="Число2Тип">
													<xs:annotation>
														<xs:documentation>Номер строки таблицы. Устрарело не применяется. Игнорируется при приёме.</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ИдТРУ" type="ГУИД32Тип">
													<xs:annotation>
														<xs:documentation>GUID товара, работы, услуги (в случае закупки лекарственных препаратов – GUID ЛП).
Соответствует значению поля guid из сведений о контракте</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ТехИдТРУ" type="xs:long">
													<xs:annotation>
														<xs:documentation>Технический идентификатор позиции ТРУ.
Соответствует значению поля sid из сведений о контракте</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ВнешТехИдТРУ" type="ВнешИдТип">
													<xs:annotation>
														<xs:documentation>Внешний технический идентификатор позиции ТРУ.
Соответствует значению поля externalSid из сведений о контракте</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="НаимТовИсх" type="Строка2000Тип" use="required">
													<xs:annotation>
														<xs:documentation>Исходное наименование ТРУ</xs:documentation>
													</xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
										<xs:element name="ДеталТРУ">
											<xs:annotation>
												<xs:documentation>Сведения о детализированных позициях ТРУ.

Если формируется исправление к документу, подписанному до выхода версии ЕИС 13.0, то блок может быть задан.

В других случаях контролируется недопустимость указания данного блока. В таких случаях сведения о позициях допускается указывать только в блоке "Сведения о позиции ТРУ" (ФайлУПДПрод/СведТов/СведТРУ/НедеталТРУ)</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="СведРод">
														<xs:annotation>
															<xs:documentation>Сведения о родительской позиции ТРУ.
В блоке указываются недетализированные позиции ТРУ из сведений о контракте (у которых отсутствуют соподчиненные позиции) или соподчиненные позиции ТРУ из сведений о контракте.
При приеме контролируется недопустимость указания позиции ТРУ из сведений о контракте, у которой есть соподчиненные позиции</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="СумНал" type="СумНДСТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сумма налога, предъявляемая покупателю.
Если установлен признак "Производить расчет НДС в итоговых строках" (РасчНДСВИтогСтр), то блок игнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="Акциз" type="СумАкцизТип">
																	<xs:annotation>
																		<xs:documentation>Сумма акциза.
Если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3", или позиция является работой или услугой, то должно быть заполнено дочернее поле "Без акциза" (БезАкциз).
В другом случае допускается указание любого дочернего поля</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СтранаПроисх" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране происхождения товара.
Принимается только в том случае, если позиция является товаром. В других случаях игнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СтранаПроизв" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране регистрации производителя товара.
Игнорируется при приеме, если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях принимается только в том случае, если позиция является товаром</xs:documentation>
																	</xs:annotation>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="ИдТРУ" type="ГУИД32Тип">
																<xs:annotation>
																	<xs:documentation>GUID товара, работы, услуги</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ТехИдТРУ" type="xs:long">
																<xs:annotation>
																	<xs:documentation>Технический идентификатор позиции ТРУ.
Соответствует значению поля sid из сведений о контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ВнешТехИдТРУ" type="ВнешИдТип">
																<xs:annotation>
																	<xs:documentation>Внешний технический идентификатор позиции ТРУ.
Соответствует значению поля externalSid из сведений о контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="КодТов" type="Строка100Тип" use="required">
																<xs:annotation>
																	<xs:documentation>Код товара</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="НаимТов" type="Строка2000Тип" use="required">
																<xs:annotation>
																	<xs:documentation>Наименование товара (работы, услуги)</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПрТовРаб" use="required">
																<xs:annotation>
																	<xs:documentation>Признак Товар/Работа/Услуга</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:length value="1"/>
																		<xs:enumeration value="1"/>
																		<xs:enumeration value="2"/>
																		<xs:enumeration value="3"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:attribute>
															<xs:attribute name="КодЕдИзм" type="КодОКЕИТип" use="optional">
																<xs:annotation>
																	<xs:documentation>Код единицы измерения.
При приеме контролируется обязательное заполнение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="НаимЕдИзм" type="Строка255Тип" use="optional">
																<xs:annotation>
																	<xs:documentation>Наименование единицы измерения.
Игнорируется при приеме, заполняется при передаче из справочника ОКЕИ</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЦенаЕдИзм" type="ЧислоМакс15ДоТочкТип" use="optional">
																<xs:annotation>
																	<xs:documentation>Цена за единицу измерения без НДС.
При приеме контролируется обязательное заполнение.
Если одновременно выполняются следующие условия, то цена за единицу может быть изменена относительно цены, указанной в связанном контракте:
- в связанном контракте в поле "Способ указания цены контракта" (priceInfo/priceType) установлено значение "MP" (Максимальное значение цены контракта);
- в связанном контракте указан один из следующих кодов ОКПД2:
19.20;
06.20.10.131;
65.11.10.110;
65.12.11.000;
65.12.12.000;
65.12.21.000;
65.12.34.000;
65.12.41.000;
65.12.49.000;
65.12.50.000;
65.12.90.000;
06.20.10.110.
Иначе цена должна быть указана в соответствии с ценой, заданной для данного объекта закупки в связанном контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="КолТов" type="ПозНегЧислоМакс15ДоТочкТип" use="optional">
																<xs:annotation>
																	<xs:documentation>Количество (объем).
Если в атрибуте "Признак Товар/Работа/Услуга" (ФайлУПДПрод/СведТов/СведТРУ/ДеталТРУ/СведРод/@ПрТовРаб) указано значение:
- 1, то данный атрибут должен быть заполнен, а его значение должно равняться сумме количества товара по всем дочерним позициям;
- 2 или 3, то данный атрибут игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ОбРабУсл" type="Строка500Тип">
																<xs:annotation>
																	<xs:documentation>Объем работы, услуги в текстовом выражении.
Если в атрибуте "Признак Товар/Работа/Услуга" (ФайлУПДПрод/СведТов/СведТРУ/ДеталТРУ/СведРод/@ПрТовРаб) указано значение:
- 1, то данный атрибут игнорируется при приеме;
- 2 или 3, то данный атрибут принимается и сохраняется, если заполнен
</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СтТовБезНДС" type="ПозНегЧислоМакс17ДоТочкТип" use="required">
																<xs:annotation>
																	<xs:documentation>Стоимость товаров (работ, услуг) без налога - всего</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="НалСт" use="required">
																<xs:annotation>
																	<xs:documentation>Налоговая ставка.

При приеме проверяется, что указанное значение присутствует в справочнике "Налоговые ставки для электронного актирования" (nsiVATEA) в актуальном статусе.

Актуальные значения (01.01.2026):
- 0%
- 5%
- 7%
- 10%
- 18%
- 20%
- 22%
- 5/105
- 7/107
- 10/110
- 18/118
- 20/120
- 22/122
- без НДС</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string"/>
																</xs:simpleType>
															</xs:attribute>
															<xs:attribute name="СтТовУчНал" type="ПозНегЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Стоимость товаров (работ, услуг) с налогом - всего.
Если установлен признак "Производить расчет НДС в итоговых строках" (РасчНДСВИтогСтр), то атрибут игнорируется при приеме, иначе обязателен для заполнения</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПозСмет" type="Строка100Тип">
																<xs:annotation>
																	<xs:documentation>Номер позиции по смете.
Игнорируется для счет-фактур.
Если атрибут "Отраслевая специализация" (ОтрСпец) заполнен значением 1 - "Строительство", то принимается и сохраняется, иначе игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
													<xs:element name="СведДетал" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>Сведения о детализированной (дочерней) позиции ТРУ</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="СтранаПроисх" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране происхождения товара.
Принимается только в том случае, если позиция является товаром. В других случаях игнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СтранаПроизв" type="СтранаТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Сведения о стране регистрации производителя товара.
Игнорируется при приеме, если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях принимается только в том случае, если позиция является товаром</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="СведПоставкиТов" type="СведПоставкиТип" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<xs:documentation>Сведения о месте поставки товара.
Принимается только в том случае, если одновременно выполняются следующие условия:
 - документ не является счет-фактурой; 
 - документ не содержит специализацию "Строительство" или "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) не заполнен значением "1" или "3".
В других случаях игнорируется при приемеигнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ВыпНачПериод" type="ВыпПериодСтоимСНДСТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Игнорируется при приеме, рассчитывается автоматически и заполняется при передаче, если задан атрибут "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог)</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="КолИлиОбСмета" type="КоличИлиОбъемТекстТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Количество или объем работы по смете.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																	</xs:annotation>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="НомСтр" type="Число6Тип" use="required">
																<xs:annotation>
																	<xs:documentation>Номер строки таблицы</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ИдТРУ" type="ГУИД32Тип" use="required">
																<xs:annotation>
																	<xs:documentation>GUID товара, работы, услуги</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ОбРабУсл" type="Строка500Тип">
																<xs:annotation>
																	<xs:documentation>Объем работы, услуги в текстовом выражении.
Контролируется обязательное заполнение данного атрибута или атрибута "Количество (объем) (графа 3 счета-фактуры)" (Файл/Документ/ТаблСчФакт/СведТов/@КолТов), указываемого в составе основого документа</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ЦенаСНДС" type="ЧислоМакс15ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Цена за единицу с НДС.
При приеме контролируется обязательное заполнение</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СтоимСметаСНДС" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Стоимость из сметы контракта с НДС.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="СтоимСметаБезНДС" type="ЧислоМакс17ДоТочкТип">
																<xs:annotation>
																	<xs:documentation>Стоимость из сметы контракта без НДС.
Игнорируется при приеме, заполняется из сметы контракта при наличии</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПозСмет" type="Строка100Тип">
																<xs:annotation>
																	<xs:documentation>Номер позиции по смете.
Игнорируется для счет-фактур.
Если атрибут "Отраслевая специализация" (ОтрСпец) заполнен значением 1 - "Строительство", то принимается и сохраняется, иначе игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ПрУлучшХаракт">
																<xs:annotation>
																	<xs:documentation>Признак поставки объекта закупки с улучшенными характеристиками:
- 1 - не установлен;
- 2 - установлен из информации о контракте;
- 3 - установлен пользователем.
Игнорируется при приеме исправления к документу, который был подписан до версии 11.2.
Игнорируется при приеме, если документ имеет специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях контролируется обязательное заполнение.
Если для родительской позиции ТРУ в сведениях о контракте установлен одноименный признак, то контролируется, что в составе данного атрибута указано значение "2 - установлен из информации о контракте".
Если для родительской позиции ТРУ в сведениях о контракте НЕ установлен одноименный признак, то контролируется, что в составе данного атрибута указано значение, отличное от "2 - установлен из информации о контракте".
В исправлении редактирование данного признака допускается только в том случае, если:
- статус документа, к которому формируется исправление - «Отказано при рассмотрении»
- в сведениях о контракте для родительской позиции не установлен признак поставки объекта закупки с улучшенными характеристиками</xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:enumeration value="1"/>
																		<xs:enumeration value="2"/>
																		<xs:enumeration value="3"/>
																	</xs:restriction>
																</xs:simpleType>
															</xs:attribute>
															<xs:attribute name="СведЖилПом" type="Строка10000Тип">
																<xs:annotation>
																	<xs:documentation>Сведения о характеристиках жилого помещения.
Атрибут обязателен для заполнения, если документ содержит специализацию "Приобретение жилых помещений", то есть атрибут "Отраслевая специализация" (СведТов/@ОтрСпец) заполнен значением "3".
В других случаях игнорируется при приеме</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:choice>
								</xs:complexType>
							</xs:element>
							<xs:element name="СведТРУСметаКонт" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Сведения о товарах, работах, услугах (ТРУ) в соответствии со сметой контракта.
Если отраслевой специализацией документа является сторительство и установлен признак накопительного итога (в атибуте "Применяется накопительный итог" (ФайлУПДПрод/СведСтройк/НастрФормДок/@ПримНакопИтог) указано значение true), то данный блок должен быть заполнен при приеме.
В составе блока должны быть указаны все позиции из сметы контракта</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:choice>
										<xs:element name="НедеталТРУ">
											<xs:annotation>
												<xs:documentation>Сведения о позиции ТРУ</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="ВыпНачПериод" type="ВыпПериодТип" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Блок может быть заполнен только в том случае, если последний документ по контракту не имеет признака накопительного итога.
В других случаях игнорируется при приеме.
Также игнорируется при приеме при наличии блока "Детализация по разделам видов работ и/или по конструктивным решениям (видам работ)" (ФайлУПДПрод/СведТов/СведТРУСметаКонт/НедеталТРУ/РазделВидРаб)</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="ВыпОтчПериод" type="ВыпПериодТип" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Выполнено за отчетный период.
Игнорируется при приеме при наличии блока "Детализация по разделам видов работ и/или по конструктивным решениям (видам работ)" (ФайлУПДПрод/СведТов/СведТРУСметаКонт/НедеталТРУ/РазделВидРаб)</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="РазделВидРаб" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Детализация по разделам видов работ и/или по конструктивным решениям (видам работ)</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="Раздел" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<xs:documentation>Раздел видов работ</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:sequence>
																			<xs:element name="ВидРаб" maxOccurs="unbounded">
																				<xs:annotation>
																					<xs:documentation>Конструктивное решение (вид работ) (УПД)</xs:documentation>
																				</xs:annotation>
																				<xs:complexType>
																					<xs:sequence>
																						<xs:element name="ВыпНачПериод" type="ВыпПериодТип" minOccurs="0">
																							<xs:annotation>
																								<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Блок может быть заполнен только в том случае, если последний документ по контракту не имеет признака накопительного итога, иначе игнорируется при приеме</xs:documentation>
																							</xs:annotation>
																						</xs:element>
																						<xs:element name="ВыпОтчПериод" type="ВыпПериодТип" minOccurs="0">
																							<xs:annotation>
																								<xs:documentation>Выполнено за отчетный период</xs:documentation>
																							</xs:annotation>
																						</xs:element>
																					</xs:sequence>
																					<xs:attribute name="ИдВидРаб" type="ГУИД32Тип" use="required">
																						<xs:annotation>
																							<xs:documentation>Идентификатор (GUID) конструктивного решения (вида работ)</xs:documentation>
																						</xs:annotation>
																					</xs:attribute>
																				</xs:complexType>
																			</xs:element>
																		</xs:sequence>
																		<xs:attribute name="ИдРаздел" type="ГУИД32Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Идентификатор (GUID) раздела</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
																<xs:element name="ВидРаб" minOccurs="0" maxOccurs="unbounded">
																	<xs:annotation>
																		<xs:documentation>Конструктивное решение (вид работ) (УПД)</xs:documentation>
																	</xs:annotation>
																	<xs:complexType>
																		<xs:sequence>
																			<xs:element name="ВыпНачПериод" type="ВыпПериодТип" minOccurs="0">
																				<xs:annotation>
																					<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Блок может быть заполнен только в том случае, если последний документ по контракту не имеет признака накопительного итога.
В других случаях игнорируется при приеме</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																			<xs:element name="ВыпОтчПериод" type="ВыпПериодТип" minOccurs="0">
																				<xs:annotation>
																					<xs:documentation>Выполнено за отчетный период</xs:documentation>
																				</xs:annotation>
																			</xs:element>
																		</xs:sequence>
																		<xs:attribute name="ИдВидРаб" type="ГУИД32Тип" use="required">
																			<xs:annotation>
																				<xs:documentation>Идентификатор (GUID) конструктивного решения (вида работ)</xs:documentation>
																			</xs:annotation>
																		</xs:attribute>
																	</xs:complexType>
																</xs:element>
															</xs:sequence>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
												<xs:attribute name="ИдТРУ" type="ГУИД32Тип">
													<xs:annotation>
														<xs:documentation>GUID товара, работы, услуги.

Устарело, игнорируется при приеме.

Для идентификации позиции используется только значение атрибута "GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования (сметы контракта)" (ФайлУПДПрод/СведТов/СведТРУСметаКонт/НедеталТРУ/@ЭАИдТРУ)</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ТехИдТРУ" type="xs:long">
													<xs:annotation>
														<xs:documentation>Технический идентификатор позиции ТРУ.

Устарело, игнорируется при приеме.

Для идентификации позиции используется только значение атрибута "GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования (сметы контракта)" (ФайлУПДПрод/СведТов/СведТРУСметаКонт/НедеталТРУ/@ЭАИдТРУ)</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ВнешТехИдТРУ" type="ВнешИдТип">
													<xs:annotation>
														<xs:documentation>Внешний технический идентификатор позиции ТРУ.

Устарело, игнорируется при приеме.

Для идентификации позиции используется только значение атрибута "GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования (сметы контракта)" (ФайлУПДПрод/СведТов/СведТРУСметаКонт/НедеталТРУ/@ЭАИдТРУ)</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="ЭАИдТРУ" type="ГУИД32Тип">
													<xs:annotation>
														<xs:documentation>GUID товара, работы, услуги, идентифицирующий позицию в составе принимаемого документа электронного актирования (сметы контракта).

Указывается идентификатор позиции, присвоенный при формировании сметы</xs:documentation>
													</xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
										<xs:element name="ДеталТРУ">
											<xs:annotation>
												<xs:documentation>Сведения о детализированных позициях ТРУ.

Контролируется недопустимость указания данного блока.

Если в поселнедней версии сметы заполнен блок "Сведения о детализированных позициях ТРУ" (ФайлСметаКонт/СведСмета/СведТРУ/ДеталТРУ), то необходимо сформировать новую версию сметы без данного блока</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="СведРод">
														<xs:annotation>
															<xs:documentation>Сведения о родительской позиции ТРУ</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:attribute name="ИдТРУ" type="ГУИД32Тип">
																<xs:annotation>
																	<xs:documentation>GUID товара, работы, услуги</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ТехИдТРУ" type="xs:long">
																<xs:annotation>
																	<xs:documentation>Технический идентификатор позиции ТРУ.
Соответствует значению поля sid из сведений о контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
															<xs:attribute name="ВнешТехИдТРУ" type="ВнешИдТип">
																<xs:annotation>
																	<xs:documentation>Внешний технический идентификатор позиции ТРУ.
Соответствует значению поля externalSid из сведений о контракте</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
													<xs:element name="СведДетал" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>Сведения о детализированной (дочерней) позиции ТРУ</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="ВыпНачПериод" type="ВыпПериодТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Выполнено с начала выполнения работ (без учета отчетного периода).
Блок может быть заполнен только в том случае, если последний документ по контракту не имеет признака накопительного итога.
В других случаях игнорируется при приеме</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="ВыпОтчПериод" type="ВыпПериодТип" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>Выполнено за отчетный период</xs:documentation>
																	</xs:annotation>
																</xs:element>
															</xs:sequence>
															<xs:attribute name="ИдТРУ" type="ГУИД32Тип" use="required">
																<xs:annotation>
																	<xs:documentation>GUID товара, работы, услуги</xs:documentation>
																</xs:annotation>
															</xs:attribute>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:choice>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
						<xs:attribute name="ОтрСпец">
							<xs:annotation>
								<xs:documentation>Отраслевая специализация:
1 - Строительство. Данная специализация должна быть указана, если для связанного контракта существует смета в завершенном статусе;
2 - Лекарственные препараты;
3 - Приобретение жилых помещений. Данная специализация может быть указана только в том случае, если в сведениях о контракте все объекты закупки имеют коды ОКПД2/КТРУ из списка 68.10.11.000, 41.20.10.190.
Игнорируется для счет-фактур</xs:documentation>
							</xs:annotation>
							<xs:simpleType>
								<xs:restriction base="xs:string">
									<xs:enumeration value="1"/>
									<xs:enumeration value="2"/>
									<xs:enumeration value="3"/>
								</xs:restriction>
							</xs:simpleType>
						</xs:attribute>
						<xs:attribute name="НаимОбСтр" type="Строка2000Тип">
							<xs:annotation>
								<xs:documentation>Наименование объекта строительства.
Игнорируется для счет-фактур.
Если атрибут "Отраслевая специализация" (ОтрСпец) заполнен значением 1 - "Строительство" И:
- для связанного контракта отсутствует смета в завершенном статусе, то контролируется обязательность заполнения;
- для связанного контракта существует смета в завершенном статусе, то игнорируется при приеме, заполняется при передаче из сметы контракта.
В других случаях игнорируется при приеме, не заполняется при передаче</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ВсегоОплСтТовУчНалВсего" type="ЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Всего к оплате, Стоимость товаров (работ, услуг) с налогом - всего (строка «Всего к оплате»/графа 9 счета-фактуры) в валюте контракта.
Заполняется, если валюта УПД не совпадает с валютой контракта</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ВсегоОплСумНал" type="ЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Всего к оплате, Сумма налога, предъявляемая покупателю (строка «Всего к оплате»/графа 8 счета-фактуры) в валюте контракта.
Заполняется, если:
значение (НДС) СумНал больше 0 и валюта УПД не совпадает с валютой контракта</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="НоминалКурсВал" type="Число6Тип">
							<xs:annotation>
								<xs:documentation>Номинал курса валюты по справочнику курсов валют на дату составления УПД</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведМестаПоставки" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения о местах поставки товаров</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="СведМестоПоставки" type="МестоПоставкиТип" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Сведения о месте поставки товаров</xs:documentation>
								</xs:annotation>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="ИтогОбжОтзакПриемТов" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Документ формируется по итогам досудебного (судебного) обжалования отказа в приемке товаров (работ, услуг).
Блок может быть заполнен только в том случае, если одновременно выполняются следующие условия:
- функция документа отлична от СЧФ;
- в рамках этапа контракта, к которому принимается документ, существует хотя бы один документ о приемке в статусе "Подписано с частичной приемкой" или "Отказано при приемке".
Если блок заполнен, то при приеме контролируется обязательность заполнения атрибута "Реквизиты документа, подтверждающего наличие соглашения сторон/решения суда" (ФайлУПДПрод/ИтогОбжОтзакПриемТов/@РеквДок), указанного в составе данного блока, или указание хотя бы одного вложения, у которого в атрибуте "Код" (ФайлУПДПрод/Вложен/ВидДок/@Код) задано одно из следующих значений:
 - 18 - Досудебное согласие;
 - 19 - Решение суда</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:attribute name="ИдФайлОбжалДок" type="ИдФайлТип" use="required">
							<xs:annotation>
								<xs:documentation>Идентификатор документа, являющегося предметом обжалования.
В атрибуте указывается идентификатор документа о приемке с функцией СЧФДОП или ДОП, сформированный в рамках этапа контракта, к которому принимаеется документ, в статусе "Подписано с частичной приемкой" или "Отказано при приемке".
Если для документа, удолветворяющего условиям выше существуют исправления, то в данном атрибуте должен указываться идентификатор последнего исправления.
Если принимаемый документ является исправлением к документу о приемке в статусе "Подписано с частичной приемкой", то в данном атрибуте должен быть указан идентификатор файла, к которому формируется исправление</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ОбжалДок" type="Строка1000Тип">
							<xs:annotation>
								<xs:documentation>Реквизиты документа, являющего предметом обжалования.
Игнорируется при приеме, заполняется при передаче реквизитами документа, являющегося предметом обжалования</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="ВидДокСогл" type="ВидДокСоглТип" use="required">
							<xs:annotation>
								<xs:documentation>Вид документа, подтверждающего наличие соглашения сторон/решения суда.
Допустимые значения:
- ДосудебнСогл - досудебное согласие;
- РешСуда - решение суда</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="РеквДокСогл" type="Строка255Тип">
							<xs:annotation>
								<xs:documentation>Реквизиты документа, подтверждающего наличие соглашения сторон/решения суда</xs:documentation>
							</xs:annotation>
						</xs:attribute>
					</xs:complexType>
				</xs:element>
				<xs:element name="СведСтройк" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Сведения, относящиеся к отраслевой специализации по строительству.
Блок может быть задан только в том случае, если в атрибуте "Отраслевая специализация" (ФайлУПДПрод/СведТов/@ОтрСпец) задано значение "1 - Строительство", иначе игнорируется при приеме</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="НастрФормДок" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Настройки для формирования документа.
При приеме исправления к документу в статусе "Подписано", "Подписано с частичной приемкой", ИЛИ для документа о приемке существует исправление в аналогичном статусе, то значения дочерних атрибутов должны совпадать со значениями аналогичных атрибутов в существующем документе</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="РасчНДСВИтогСтр" type="xs:boolean">
										<xs:annotation>
											<xs:documentation>Производить расчет НДС в итоговых строках.
Значение true может быть задано только в том случае, если документ имеет функцию ДОП.
Если для связанного контракта существует смета в завершенном статусе, то игнорируется при приеме, при передче заполняется значением true</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ОкрСтоимДоЦелых" type="xs:boolean">
										<xs:annotation>
											<xs:documentation>Округлять стоимость до целых значений.
Игнорируется при приеме/передаче.
Оставлен для обратной совестимости</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="НаимСтолбцТабл" type="НаимСтолбцТаблДляСтройТип">
										<xs:annotation>
											<xs:documentation>Наименования столбцов таблицы.
Допустимые значения:
НаимКонстрРеш - наименование конструктивных решений (элементов), комплексов (видов) работ, затрат, оборудования;
НаимРаб - наименование работ</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ПримНакопИтог" type="xs:boolean">
										<xs:annotation>
											<xs:documentation>Применяется накопительный итог.
Если для связанного контракта существует смета в завершенном статусе, то контролируется, что данном атрибуте задано значение true.
В других случаях игнорируется при приеме</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ПоследДокумент" type="xs:boolean">
										<xs:annotation>
											<xs:documentation>Последний документ по контракту.
Принимается только в том случае, если задан атрибут "Применяется накопительный итог" (ПримНакопИтог).
В других случаях игнорируется при приеме</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="СведИнвестор" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Сведения об инвесторе</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="Наим" type="Строка1000Тип" use="required">
										<xs:annotation>
											<xs:documentation>Наименование/ФИО</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ИНН" type="ИННТип" use="required">
										<xs:annotation>
											<xs:documentation>ИНН</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="КПП" type="КППТип">
										<xs:annotation>
											<xs:documentation>КПП</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="ПрочиеНачислен" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Прочие начисления.
Блок принимается только в том случае, если задан атрибут "Применяется накопительный итог" (ПримНакопИтог) и в сведениях о контракте установлен признак "Удержание суммы неисполненных поставщиком (подрядчиком, исполнителем) требований об уплате неустоек (штрафов, пеней), предъявленных заказчиком, из суммы, подлежащей уплате поставщику (подрядчику, исполнителю)".
В других случаях игнорируется при приеме</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence>
										<xs:element name="ИнфНачислНеуст" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Информация о начисленной неустойке (штрафе, пени) и уменьшении суммы оплаты</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="ТребЗакНеуст" type="ТребЗакНеустТип" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>Требование заказчика об уплате неустойки (штрафа, пени)</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:sequence>
									<xs:attribute name="СумНеуст" type="ЧислоМакс20ДоТочкТип">
										<xs:annotation>
											<xs:documentation>Итоговая сумма неустоек (штрафов, пени).
Игнорируется при приеме, рассчитывается автоматически и заполняется при передаче</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="НачПерСумНеуст" type="ЧислоМакс20ДоТочкТип">
										<xs:annotation>
											<xs:documentation>Итоговая сумма неустоек (штрафов, пени) с начала периода.
Игнорируется при приеме, рассчитывается автоматически и заполняется при передаче</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="СумЗачетАванс" type="ЧислоМакс20ДоТочкТип">
										<xs:annotation>
											<xs:documentation>Сумма зачета аванса по документу о приемке.
Атрибут может быть заполнен только в том случае, если заказчик по контракту входит в список заказчиков Департамента строительства г. Москвы.
В других случаях игнорируется при приеме</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="НачПерСумЗачетАванс" type="ЧислоМакс20ДоТочкТип">
										<xs:annotation>
											<xs:documentation>Сумма зачета аванса по документу о приемке с начала периода.
Игнорируется при приеме, рассчитывается автоматически и заполняется при передаче</xs:documentation>
										</xs:annotation>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
							<xs:element name="СведСмета" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Сведения о смете контракта.
Игнорируется при приеме.
Если для контракта, к которому формируется документ о приеме, существует смета контракта, то заполняется при передаче</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:attribute name="ИдСмета" type="ГУИД32Тип" use="required">
										<xs:annotation>
											<xs:documentation>Идентификатор сметы, присвоенный в ЕИС</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ВнешИдСмета" type="ВнешИдТип">
										<xs:annotation>
											<xs:documentation>Внешний идентификатор сметы</xs:documentation>
										</xs:annotation>
									</xs:attribute>
									<xs:attribute name="ВерсСмета" use="required">
										<xs:annotation>
											<xs:documentation>Версия сметы</xs:documentation>
										</xs:annotation>
										<xs:simpleType>
											<xs:restriction base="xs:int">
												<xs:minInclusive value="1"/>
											</xs:restriction>
										</xs:simpleType>
									</xs:attribute>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
						<xs:attribute name="ВсегоСумНеОблНал" type="ПозНегЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Сумма, не облагаемая налогом (по ставке «Без НДС» и 0%)</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="СумНал5" type="ПозНегЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Сумма налога по ставке 5%.
Может быть задан только в том случае, если установлен признак "Производить расчет НДС в итоговых строках" (РасчНДСВИтогСтр)</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="СумНал7" type="ПозНегЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Сумма налога по ставке 7%.
Может быть задан только в том случае, если установлен признак "Производить расчет НДС в итоговых строках" (РасчНДСВИтогСтр)</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="СумНал10" type="ПозНегЧислоМакс17ДоТочкТип">
							<xs:annotation>
								<xs:documentation>Сумма налога по ставке 10%.
Может быть задан только в том случае, если установлен признак "Производить расчет НДС в итоговых строках" (РасчНДСВИтогСтр)</xs:documentation>
							</xs:annotation>
						</xs:attribute>
						<xs:attribute name="СумНал20" type="ПозНегЧислоМакс17ДоТочкТип">
							<xs:annotation>
