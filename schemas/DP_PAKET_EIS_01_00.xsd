						</xs:annotation>
					</xs:attribute>
					<xs:attribute name="НаимРаздел" type="Строка500Тип" use="required">
						<xs:annotation>
							<xs:documentation>Наименование раздела</xs:documentation>
						</xs:annotation>
					</xs:attribute>
					<xs:attribute name="СтоимБезНДСРаздел" type="ЧислоМакс17ДоТочкТип">
