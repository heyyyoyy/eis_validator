		</xs:annotation>
		<xs:attribute name="Код" type="Строка10Тип" use="required">
			<xs:annotation>
				<xs:documentation>Код</xs:documentation>
			</xs:annotation>
		</xs:attribute>
		<xs:attribute name="Наим" type="Строка255Тип">
			<xs:annotation>
				<xs:documentation>Полное наименование.
Игнорируется при приеме, заполняется при передаче значением из справочника ОЕИ</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
