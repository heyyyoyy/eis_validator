Игнорируется при приеме, рассчитывается автоматически</xs:documentation>
						</xs:annotation>
					</xs:attribute>
				</xs:complexType>
			</xs:element>
			<xs:element name="ВидРаб" type="ВидРабСметаТип" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Конструктивное решение (вид работ)</xs:documentation>
				</xs:annotation>
			</xs:element>
